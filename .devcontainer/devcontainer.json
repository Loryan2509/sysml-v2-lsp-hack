{
  "name": "SysML v2 LSP",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13",
      "installJupyterlab": false
    }
  },
  "postCreateCommand": "npm install && npm run generate && pip3 install --user jupyter ipykernel notebook",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "ms-toolsai.jupyter",
        "ms-python.python"
      ],
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  }
}